<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contato - <%= anuncio ? anuncio.titulo : 'Anúncio' %> - CPC</title>
  <link rel="stylesheet" href="/css/contato-troca.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap">
</head>

<%- include('../partials/header.ejs') %>
<body>
  <main>

    <% if (!anuncio) { %>
      <p style="text-align:center;padding:40px">Anúncio não encontrado. <a href="/todos">Voltar aos anúncios</a></p>
    <% } else { %>

    <!-- Perfil do Doador -->
    <section class="profile-section">
      <figure class="profile-card">
        <img src="<%= anuncio.foto %>" alt="Foto de perfil" class="avatar">
        <figcaption class="user-info">
          <h1 class="name"><%= anuncio.doadorNome %></h1>
          <p class="details">
            <span class="profession"><%= anuncio.titulo %></span><br>
            <span class="trades-count"><%= anuncio.pontos %> Pontos · <%= anuncio.categoria %></span>
          </p>
        </figcaption>
      </figure>
    </section><br>

    <% const defaultSliderImages = {
         profissionais: ['/img/servicos.jpeg', '/img/img2-home.jpeg', '/img/img home-2.png'],
         alimentos: ['/img/img alimentacao.jpeg', '/img/leite.webp', '/img/img2-home.jpeg'],
         infantil: ['/img/img kids.jpeg', '/img/img2-home.jpeg', '/img/img home-2.png'],
         default: ['/img/img2-home.jpeg', '/img/img cpc-verde.jpeg', '/img/servicos.jpeg']
       };
       const sliderImages = defaultSliderImages[anuncio.categoria] || defaultSliderImages.default;
    %>
    <!-- Carrossel -->
    <section class="carousel-section">
      <section class="slider-container">
        <input type="radio" name="slider" id="slide1" checked>
        <input type="radio" name="slider" id="slide2">
        <input type="radio" name="slider" id="slide3">
        <section class="slider-img-wrapper">
          <section class="slider-track" id="image-track">
            <img src="<%= sliderImages[0] %>" class="slider-img" alt="Imagem 1">
            <img src="<%= sliderImages[1] %>" class="slider-img" alt="Imagem 2">
            <img src="<%= sliderImages[2] %>" class="slider-img" alt="Imagem 3">
          </section>
        </section>
        <section class="slider-circles">
          <label for="slide1" class="circle"></label>
          <label for="slide2" class="circle"></label>
          <label for="slide3" class="circle"></label>
        </section>
      </section>
    </section>

    <!-- Descrição -->
    <section class="description-section">
      <h2>Descrição</h2>
      <p><%= anuncio.descricao %></p>
      <p style="margin-top:10px"><strong>Localização:</strong> <%= anuncio.doadorLocal %></p>
      <p><strong>Tipo:</strong> <%= anuncio.tipo === 'servico' ? 'Serviço' : 'Produto' %></p>
    </section>

    <!-- Ação -->
    <section class="action-section">
      <a href="/resumo/<%= anuncio.id %>" class="start-trade-button-link">
        <button type="button" class="start-trade-button"><strong>Iniciar Troca</strong></button>
      </a>
    </section>

    <% } %>
  </main>

  <script>
    const slides = [document.getElementById('slide1'), document.getElementById('slide2'), document.getElementById('slide3')];
    let current = 0;
    setInterval(() => {
      slides[current].checked = false;
      current = (current + 1) % slides.length;
      slides[current].checked = true;
    }, 2300);
    const sliderWrapper = document.querySelector('.slider-img-wrapper');
    let startX = null;
    sliderWrapper && sliderWrapper.addEventListener('touchstart', e => startX = e.touches[0].clientX);
    sliderWrapper && sliderWrapper.addEventListener('touchend', e => {
      if (startX === null) return;
      const diff = e.changedTouches[0].clientX - startX;
      if (Math.abs(diff) > 50) {
        slides[current].checked = false;
        current = diff < 0 ? (current + 1) % slides.length : (current - 1 + slides.length) % slides.length;
        slides[current].checked = true;
      }
      startX = null;
    });
  </script>
</body>
<%- include('../partials/footer.ejs') %>
</html>