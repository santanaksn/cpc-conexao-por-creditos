<!DOCTYPE html>
<html lang="pt-BR" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Perfil</title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap%22 rel="stylesheet">
  <link rel="stylesheet" href="../css/conta.css" />
</head>
<%- include('../partials/header.ejs') %>
 
<body>
  <main class="container">
    <!-- Profile Section -->
    <section class="profile">
      <section class="profile-image">
        <img src="<%= usuario?.foto || '/img/img perfil-white.png' %>" alt="Foto de perfil de <%= usuario?.nome || 'usuário' %>" loading="lazy" />
      </section>
      <section class="profile-header">
        <h1><%= usuario?.nome || 'Usuário' %></h1>
        <% if (usuario?.provider) { %>
          <span class="provider-label"><%= usuario.provider === 'google' ? 'Entrou com Google' : usuario.provider === 'local' ? 'Login local' : 'Entrou com ' + usuario.provider %></span>
        <% } %>
      </section>
      <p><%= usuario?.email || 'Sem e-mail cadastrado' %></p>
    </section>

    <form action="/upload" method="POST" enctype="multipart/form-data"><label>Escolha uma foto (JPG ou PNG):</label>
    <input type="file" name="minhaImagem" accept="img/*" required><button type="submit">Subir e Converter</button></form>

    <form action="/enviar-foto" method="POST" enctype="multipart/form-data"><input type="file" name="imagemUsuario" accept="img/*">
    <button type="submit">Upload Inteligente</button></form>
 
    <!-- Credit Balance -->
    <section class="balance-card">
        <section class="balance-amount">
          <span class="amount">Você acumulou 100 créditos<!-- <img src="/img/img-creditos.png" alt="Ícone de créditos">--></span>
        </section>
      </section>
 
      <!-- Bento Grid -->
      <section class="bento-grid">
        <!-- In-Progress Trades -->
        <section class="trades-section">
          <h2>Últimas Trocas</h2>
         
          <% if (meusTrocas && meusTrocas.length > 0) { %>
            <% meusTrocas.slice(0, 3).forEach(troca => { %>
              <% 
                const dataTroca = new Date(troca.dataSolicitacao);
                const dia = String(dataTroca.getDate()).padStart(2, '0');
                const mes = String(dataTroca.getMonth() + 1).padStart(2, '0');
                const ano = dataTroca.getFullYear();
                const dataFormatada = `${dia}/${mes}/${ano}`;
                const statusClasse = troca.status === 'concluida' ? 'status-concluido' : 'status-andamento';
                const statusTexto = troca.status === 'concluida' ? 'CONCLUÍDO' : 'ANDAMENTO';
              %>
              <section class="trade-card">
                <section class="trade-icon">
                  <img src="<%= troca.foto %>" alt="Foto de <%= troca.doadorNome %>">
                </section>
                <section class="trade-info">
                  <p class="trade-type"><%= dataFormatada %></p>
                  <p class="trade-type"><%= troca.doadorNome %></p>
                  <p class="trade-name"><%= troca.anuncioTitulo %></p>
                </section>
                <section class="trade-status status-badge <%= statusClasse %>"><%= statusTexto %></section>
              </section>
            <% }) %>
          <% } else { %>
            <section style="padding: 20px; text-align: center; color: #999;">
              <p>Nenhuma troca realizada ainda</p>
            </section>
          <% } %>
        </section>
       
        <section class="trades-section">
          <h2>Ofertas Ativas</h2>
         
          <section class="trade-card">
            <section class="trade-icon">
            </section>
            <section class="trade-info">
              <p class="trade-type">07/05/2026</p>
              <p class="trade-type">Marcos Vinicius</p>
              <p class="trade-name">Limpeza</p>
            </section>
            <section class="trade-status status-badge status-inativa">INATIVA</section>
          </section>
 
          <section class="trade-card">
            <section class="trade-icon">
            </section>
            <section class="trade-info">
              <p class="trade-type">05/05/2026</p>
              <p class="trade-type">Matheus Barbosa</p>
              <p class="trade-name">Limpeza</p>
            </section>
            <section class="trade-status status-badge status-ativa">ATIVA</section>
          </section>
 
          <section class="trade-card">
            <section class="trade-icon">
            </section>
            <section class="trade-info">
              <p class="trade-type">04/05/2026</p>
              <p class="trade-type">Gibson Leonesio</p>
              <p class="trade-name">Limpeza</p>
            </section>
            <section class="trade-status status-badge status-ativa">ATIVA</section>
          </section>
        </section>
  </main>
 
   <!-- Logout -->
    <section class="logout-section">
      <a href="/logout" class="logout-btn">Sair da Conta</a>
    </section>
 
    <%- include('../partials/footer.ejs') %>
</body>
</html>